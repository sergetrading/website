# Caddy Reverse-Proxy mit automatischem HTTPS (Let's Encrypt)
# Caddy holt das Zertifikat selbstständig, sobald die Domain auf den VPS zeigt.

{
	# E-Mail für Let's-Encrypt-Benachrichtigungen
	email sergej.hoffmann@gmail.com
}

# Hauptdomain -> leitet an die Next.js-App (Container "web", Port 3000)
crestmont.consulting {
	encode gzip zstd
	reverse_proxy web:3000
}

# www -> auf die Hauptdomain umleiten
www.crestmont.consulting {
	redir https://crestmont.consulting{uri} permanent
}
