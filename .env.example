# Kopiere diese Datei zu ".env" und passe die Werte an.
# Auf dem Hostinger-VPS bzw. lokal neben der docker-compose.yml ablegen.

# Deine Domain (z.B. meinprojekt.de oder www.meinprojekt.de).
# Solange leer -> Seite läuft nur per HTTP über die VPS-IP, kein HTTPS.
# Sobald gesetzt UND die Domain per A-Record auf die VPS-IP zeigt,
# holt Traefik automatisch ein Let's-Encrypt-Zertifikat (HTTPS).
DOMAIN=

# E-Mail für Let's-Encrypt-Benachrichtigungen (Zertifikatsablauf etc.)
ACME_EMAIL=sergej.hoffmann@gmail.com
